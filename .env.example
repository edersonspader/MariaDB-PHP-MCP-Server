# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mcp
DB_USER=mcp
DB_PASS=

# Query timeout in seconds (default: 30)
DB_QUERY_TIMEOUT=30

# Maximum rows returned per page for SELECT queries (default: 500)
DB_MAX_ROWS=500

# Log executed SQL statements to var/logs/mcp.log (default: false)
DB_LOG_SQL=false

