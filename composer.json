{
  "require": {
    "php": "^8.5",
    "mcp/sdk": "^0.4",
    "monolog/monolog": "^3.0",
    "psr/log": "^3.0",
    "vlucas/phpdotenv": "^5.6",
    "symfony/cache": "^8.0",
    "psr/simple-cache": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "scripts": {
    "serve": "php server.php",
    "test": "vendor/bin/phpunit",
    "stan": "vendor/bin/phpstan analyse"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.0",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0"
  }
}
